rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // User avatars
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Project proof of work images
    match /projects/{projectId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null; // Ideally check if owner of project document
    }
  }
}
