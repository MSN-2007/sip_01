rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Projects: Anyone can read, only owners can create/update/delete
    match /projects/{projectId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId);
    }

    // Communities: Anyone can read, only owners can edit metadata
    match /communities/{communityId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId);

      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
        allow delete: if isOwner(resource.data.senderId);
      }
    }

    // Direct Messages — simpler rules, no cross-document get() needed
    match /direct_messages/{chatId} {
      // Allow any signed-in user to read/write the parent chat doc if their uid is part of the chatId
      allow read, write: if isSignedIn() && chatId.matches('.*' + request.auth.uid + '.*');

      // Allow any signed-in user to read/create messages in a chat they belong to
      match /messages/{messageId} {
        allow read: if isSignedIn() && chatId.matches('.*' + request.auth.uid + '.*');
        allow create: if isSignedIn()
          && chatId.matches('.*' + request.auth.uid + '.*')
          && request.resource.data.from == request.auth.uid;
      }
    }

    // Users: Profiles are public, but only owners can edit
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // Connections: Only participants can read/write
    match /connections/{connectionId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.from ||
        request.auth.uid == resource.data.to
      );
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.from;
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.to ||
        request.auth.uid == resource.data.from
      );
      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.from ||
        request.auth.uid == resource.data.to
      );
    }
  }
}
