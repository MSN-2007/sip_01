rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Projects: Anyone can read, only owners can create/update/delete
    match /projects/{projectId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId);
    }

    // Communities: Anyone can read, only signed in users can write
    match /communities/{communityId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // Direct Messages: Only participants can read/write
    match /direct_messages/{chatId} {
      // Check if the current user's UID is part of the chatId (which is format uid1_uid2)
      function isParticipant(chatId) {
        return isSignedIn() && chatId.matches('.*' + request.auth.uid + '.*');
      }
      
      allow read, update, create: if isParticipant(chatId);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isParticipant(chatId);
        allow create: if isParticipant(chatId) && request.resource.data.from == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // Users: Profiles are public, but only owners can edit
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // Connections: Relaxed for debugging
    match /connections/{connectionId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();
    }
  }
}
