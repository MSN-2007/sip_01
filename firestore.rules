rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Schema Validation Helpers
    function isValidProject() {
      return request.resource.data.userId == request.auth.uid;
    }

    function isValidMessage() {
      return request.resource.data.userId == request.auth.uid;
    }

    // Projects: Anyone can read, only owners can create/update/delete
    match /projects/{projectId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidProject();
      allow update, delete: if isOwner(resource.data.userId);
    }
    
    // Communities: Anyone can read, only owners can edit metadata
    match /communities/{communityId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) || (
        // Allow members to update ONLY their joined Status (if implemented via array)
        // But for metadata, only owner
        isOwner(resource.data.userId)
      );
      
      // Subcollection for messages
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isValidMessage();
        allow delete: if isOwner(resource.data.userId);
      }
    }
    
    // Users: Profiles are public, but only owners can edit
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }
    
    // Connections: Only participants can read/write
    match /connections/{connectionId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.from || 
        request.auth.uid == resource.data.to
      );
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.from;
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.to || // Target can accept
        request.auth.uid == resource.data.from  // Requester can cancel/withdraw
      );
      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.from || 
        request.auth.uid == resource.data.to
      );
    }
  }
}
